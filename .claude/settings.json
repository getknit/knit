{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gradle-lint-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Running ./gradlew lint"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gradle-detekt-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Running ./gradlew detekt"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gradle-ktlint-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Running ./gradlew ktlint"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/lintorama-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Running lintorama"
          }
        ]
      }
    ]
  }
}
