{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gradle-lint-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Running ./gradlew lint"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gradle-detekt-edit.sh\"",
            "timeout": 300,
            "statusMessage": "Running ./gradlew detekt"
          }
        ]
      }
    ]
  }
}
