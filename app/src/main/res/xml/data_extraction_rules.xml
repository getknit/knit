<?xml version="1.0" encoding="utf-8"?><!--
   Data-extraction rules for API 31+. Exclude every secret and the encrypted database from BOTH cloud
   backup and device-to-device transfer: the AndroidKeyStore wrapping key is non-exportable, so db.key
   / identity.key are useless once copied off-device, and the encrypted knit.db has no value elsewhere.
   DataStore (settings, block list) is excluded as mildly private. allowBackup stays true so the rules
   apply; this realises the "excluded from backup" contract documented in DatabaseKey / KeystoreSecret.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="db.key" />
        <exclude domain="file" path="identity.key" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="database" path="knit.db" />
        <exclude domain="database" path="knit.db-wal" />
        <exclude domain="database" path="knit.db-shm" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="db.key" />
        <exclude domain="file" path="identity.key" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="database" path="knit.db" />
        <exclude domain="database" path="knit.db-wal" />
        <exclude domain="database" path="knit.db-shm" />
    </device-transfer>
</data-extraction-rules>
