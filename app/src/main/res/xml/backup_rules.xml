<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules for devices on API < 31 (API 31+ uses data_extraction_rules.xml).

   Exclude every secret and the encrypted database from cloud backup. The AndroidKeyStore wrapping
   key is non-exportable and never leaves the device, so backing up db.key / identity.key only ships
   blobs that are undecryptable off-device — and the encrypted knit.db likewise has no value off the
   originating device. DataStore (settings, block list) is excluded as mildly private. This matches
   the "excluded from cloud backup" contract documented in DatabaseKey / KeystoreSecret.
-->
<full-backup-content>
    <exclude domain="file" path="db.key" />
    <exclude domain="file" path="identity.key" />
    <exclude domain="file" path="datastore/" />
    <exclude domain="database" path="knit.db" />
    <exclude domain="database" path="knit.db-wal" />
    <exclude domain="database" path="knit.db-shm" />
</full-backup-content>
