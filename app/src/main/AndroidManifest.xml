<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Mesh transport plane 1: Wi-Fi Aware (NAN). Crucially NO location permission —
         NEARBY_WIFI_DEVICES with neverForLocation covers Wi-Fi Aware discovery on API 33+. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Data path (NDP): request the Aware network and open a TCP socket over its link-local IPv6. -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Wi-Fi Aware is a hardware feature; required=false so the app still installs on devices without
         it (they surface an "unsupported" state at runtime rather than being filtered off the store). -->
    <uses-feature android:name="android.hardware.wifi.aware" android:required="false" />

    <!-- Mesh transport plane 2: Bluetooth LE (advertise/scan for discovery + presence/RSSI, L2CAP CoC for
         the data socket). neverForLocation on BLUETOOTH_SCAN keeps the app location-free like the Wi-Fi
         plane — identity is the nodeId, RSSI is proximity-only, never location. No legacy BLUETOOTH/
         BLUETOOTH_ADMIN (those are maxSdk 30; minSdk here is 33). -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <!-- QR identity verification (scan a peer's key) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Always-on mesh foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".KnitApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Knit">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Knit"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- System share sheet: receive text or a single image from another app (ACTION_SEND).
                 The grant ride-along on EXTRA_STREAM lets us read the image via ContentResolver with
                 no storage permission. singleTask re-delivers shares to onNewIntent when running. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/plain" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <!-- ZXing's CaptureActivity (QR identity scanner) is declared android:screenOrientation="sensorLandscape"
             in the library manifest, which forces the scanner into landscape. We scan with
             setOrientationLocked(false) (ProfileDetailsScreen), so ZXing leaves the manifest orientation in
             force rather than pinning the current one — override it to fullUser so the scanner opens in the
             device's current orientation (typically portrait) and still rotates to landscape per auto-rotate. -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            android:screenOrientation="fullUser"
            tools:replace="android:screenOrientation" />

        <service
            android:name=".mesh.MeshService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <receiver
            android:name=".notifications.NotificationDismissReceiver"
            android:exported="false" />

        <!-- Hands our own APK to the system share sheet (Quick Share / Bluetooth) so a user can pass
             Knit to a nearby phone offline. Outbound only; the receiver's OS installs it. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
