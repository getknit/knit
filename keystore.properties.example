# Release signing (Google Play upload key) — COPY this file to `keystore.properties` (gitignored) and fill
# it in, OR set the KNIT_UPLOAD_* env vars instead (CI). If neither is present, `assembleRelease` builds
# UNSIGNED (which is fine for exercising R8; a signing key is only needed to install on a device or upload
# to Play). NEVER commit the real keystore.properties or the .jks/.keystore file.
#
# Generate an upload keystore once (RSA 2048, 10000-day validity), then reference it below:
#   keytool -genkeypair -v -keystore knit-upload.jks -alias knit-upload \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile may be absolute or relative to the repo root.
storeFile=knit-upload.jks
storePassword=CHANGE_ME
keyAlias=knit-upload
keyPassword=CHANGE_ME
